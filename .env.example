# 通用环境变量说明。Docker 一键部署请直接使用：
#   cp deploy/env.example .env
# 详见仓库根目录 DEPLOY.md

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=请改为足够长的随机字符串
DJANGO_ALLOWED_HOSTS=你的域名.com,www.你的域名.com

# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_INSECURE_COOKIES=1
# DJANGO_SQLITE_PATH=/data/db.sqlite3
# DJANGO_CORS_ALLOWED_ORIGINS=https://前端域名
# VITE_API_BASE_URL=https://api.你的域名.com/api/v1/

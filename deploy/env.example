# 复制到仓库根目录并重命名为 .env：
#   cp deploy/env.example .env

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=请改为 openssl rand -hex 32 生成的长随机串
DJANGO_ALLOWED_HOSTS=你的域名或公网IP,localhost,127.0.0.1

# 尚未配置 HTTPS 时设为 1（配置好证书后改为 0 并开启 DJANGO_SECURE_SSL_REDIRECT）
DJANGO_INSECURE_COOKIES=1

# 与 nginx 同域反代时保持默认（前端请求 /api/v1/）
VITE_API_BASE_URL=/api/v1/

# 对外端口
HTTP_PORT=80

# 可选：HTTPS 在反代终止后
# DJANGO_SECURE_SSL_REDIRECT=1

# 可选：前后端不同域时才需要
# DJANGO_CORS_ALLOWED_ORIGINS=https://你的前端域名
